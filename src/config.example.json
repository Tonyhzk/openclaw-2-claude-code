{
  "auth_key": "sk-your-proxy-auth-key-here",
  "connect_timeout": 10,
  "timeout": 300,
  "debug": false,
  "circuit_breaker": {
    "enabled": true,
    "threshold": 3,
    "timeout": 60
  },
  "providers": [
    {
      "name": "provider1",
      "enabled": true,
      "baseUrl": "https://your-provider-1.example.com",
      "apiKey": "sk-provider1-api-key",
      "injectHeaders": {
        "anthropic-beta": "+prompt-caching-2024-07-31,extended-cache-ttl-2025-04-11"
      },
      "modelMap": {
        "claude-opus-4-5": "claude-3-5-sonnet-20241022",
        "claude-sonnet-4-5": "claude-3-5-haiku-20241022"
      },
      "pathMap": {
        "/v1/messages": "/claude"
      },
      "bodyInject": {
        "max_tokens": 8192
      },
      "thinking": false
    },
    {
      "name": "provider2",
      "enabled": true,
      "baseUrl": "https://your-provider-2.example.com",
      "apiKey": "sk-provider2-api-key",
      "injectHeaders": {
        "anthropic-beta": "+prompt-caching-2024-07-31,extended-cache-ttl-2025-04-11"
      },
      "thinking": true
    },
    {
      "name": "provider3",
      "enabled": true,
      "baseUrl": "https://your-provider-3.example.com",
      "apiKey": "sk-provider3-api-key",
      "thinking": {"budget_tokens": 16000}
    }
  ]
}
